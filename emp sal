using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace EmployeeSalary
{
    class Program
    {
        static void Main(string[] args) 
        {
            Console.WriteLine("Enter the size of array : ");
            int n = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine("Enter employee salary");
            int[] salary = new int[n];
            for (int i = 0; i < salary.Length; i++)
            {

                salary[i] = int.Parse(Console.ReadLine());

            }
            int[] avg = Array.FindAll(salary,x => x >= 10000  && x <= 20000);
            Console.WriteLine("average salary of employee");
            foreach (int sal in avg)
            {
                Console.WriteLine(salary);

            }
            int[] low = Array.FindAll(salary, x => x <= 15000);
            Console.WriteLine("lowest salary of employee");
            foreach (int sal in low)
            {
                Console.WriteLine(salary);

            }
            int[] hig = Array.FindAll(salary, x => x >= 30000);
            Console.WriteLine("highest salary of employee");
            foreach (int sal in hig)
            {
                Console.WriteLine(salary);
            }
            Console.ReadKey();
        }
    }
}
